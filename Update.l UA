-- ==================== [REGISTERED BACKGROUND ENGINE] ====================
pcall(function()
  if _G.G_FP then service.unregisterReceiver(_G.G_FP); _G.G_FP = nil end
end)

_G.G_FP = LuaBroadcastReceiver(function(context, intent)
  if intent == nil then return true end
  local action = intent.getAction()
  local L = getL()
  _G.resetAutoActiveTimerOnTouch()
  
  if action == Intent.ACTION_SCREEN_OFF then
    stopAutoActiveTimer()
    if _G.prefs.getBoolean("auto_s", false) or _G.isSecEnabled then 
      acquireWake()
      local customLockCmd = _G.prefs.getString("custom_lock_command", "")
      if customLockCmd ~= "" then bgSpeak(customLockCmd) else bgSpeak(L.s_en) end
      mainHandler.postDelayed(Runnable({run = function() _G.toggleSec(true, true) end}), 450)
    end

  elseif action == Intent.ACTION_USER_PRESENT then
    if _G.isSecEnabled then
      _G.isSecEnabled = false
      _G.isProximityBlocked = false
      playAlert(false)
      pcall(function()
        if _G.m_listener then sensorManager.unregisterListener(_G.m_listener) end
        if _G.p_listener then sensorManager.unregisterListener(_G.p_listener) end
      end)
      clearUiState()
      local customUnlockCmd = _G.prefs.getString("custom_unlock_command", "")
      if customUnlockCmd ~= "" then bgSpeak(customUnlockCmd) else bgSpeak(L.s_dis) end
    end
    startAutoActiveTimer()

  elseif action == Intent.ACTION_POWER_CONNECTED then
    if _G.prefs.getBoolean("chg_p_enabled", false) then
      _G.isChargingActive = true
      acquireWake()
      bgSpeak(L.chg_en or "Charging protection system initiated.") 
    end

  elseif action == Intent.ACTION_POWER_DISCONNECTED then
    if _G.prefs.getBoolean("chg_p_enabled", false) and _G.isChargingActive then
      _G.currentReason = "charging"
      acquireWake()
      mainHandler.post(Runnable({
        run = function()
          playAlert(true)
          _G.showPIN(false)
        end
      }))
    end
  end
  return true
end)

