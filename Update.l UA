local function stopAutoActiveTimer()
  if autoActiveRunnable ~= nil then
    mainHandler.removeCallbacks(autoActiveRunnable)
    autoActiveRunnable = nil
  end
end

local function startAutoActiveTimer()
  stopAutoActiveTimer()
  if not _G.prefs.getBoolean("f_autoact_enabled", false) then return end
  local minutes = _G.prefs.getInt("f_autoact_time", 1)
  local delayMillis = minutes * 60 * 1000
  
  autoActiveRunnable = Runnable({
    run = function()
      if not _G.isSecEnabled and not _G.isAlerting then
        bgSpeak("Security Activated")
        _G.toggleSec(true, true) 
      end
    end
  })
  mainHandler.postDelayed(autoActiveRunnable, delayMillis)
end

_G.resetAutoActiveTimerOnTouch = function()
  if _G.prefs.getBoolean("f_autoact_enabled", false) and not _G.isSecEnabled then
    startAutoActiveTimer()
  end
end

-- [SENSORS INTERLOCK LOOPS]
_G.toggleSec = function(enable, silent)
  local L = getL()
  pcall(function()
    if _G.m_listener then sensorManager.unregisterListener(_G.m_listener) end
    if _G.p_listener then sensorManager.unregisterListener(_G.p_listener) end
  end)
  
  if enable then
    _G.isSecEnabled = true
    acquireWake()
    
    _G.p_listener = SensorEventListener({
      onSensorChanged = function(event)
        if event.values[0] < event.sensor.getMaximumRange() then 
          _G.isProximityBlocked = true
          _G.currentReason = "proximity"
          playAlert(true) 
        else
          _G.isProximityBlocked = false
          if _G.currentReason == "proximity" then playAlert(false) end
        end
      end
    })
    
    _G.m_listener = SensorEventListener({
      onSensorChanged = function(event)
        if _G.isAlerting and _G.currentReason == "motion" then return end
        local g = math.sqrt(event.values[0]^2 + event.values[1]^2 + event.values[2]^2)
        
        if math.abs(g - 9.8) > 1.5 then 
          _G.currentReason = "motion"
          playAlert(true) 
          if not _G.isProximityBlocked then _G.showPIN(false) end
        end
      end
    })
    
    sensorManager.registerListener(_G.p_listener, sensorManager.getDefaultSensor(8), SensorManager.SENSOR_DELAY_FASTEST)
    sensorManager.registerListener(_G.m_listener, sensorManager.getDefaultSensor(1), SensorManager.SENSOR_DELAY_FASTEST)
    
    if not silent then
      local customLockCmd = _G.prefs.getString("custom_lock_command", "")
      if customLockCmd ~= "" then bgSpeak(customLockCmd) else bgSpeak(L.s_en) end
    end
  else
    _G.isSecEnabled = false
    _G.isProximityBlocked = false
    playAlert(false)
    pcall(function() if wakeLock ~= nil and wakeLock.isHeld() then wakeLock.release(); wakeLock = nil end end)
    
    if not silent then
      local customUnlockCmd = _G.prefs.getString("custom_unlock_command", "")
      if customUnlockCmd ~= "" then bgSpeak(customUnlockCmd) else bgSpeak(L.s_dis) end
    end 
  end
end

