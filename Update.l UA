-- ==================== [CUSTOM FILE SELECTOR] ====================
local function openCustomSoundPicker()
  local currentPath = "/storage/emulated/0"
  local pickerDialog = nil
  
  local function showFolderContents(path)
    if pickerDialog != nil then pcall(function() pickerDialog.dismiss() end) end
    pickerDialog = LuaDialog(service)
    pickerDialog.setTitle("Select Audio File")
    pickerDialog.setCancelable(true)
    
    local mainLayout = LinearLayout(service).setOrientation(1).setPadding(25, 25, 25, 25).setBackground(getUniqueBackground())
    local pathTxt = TextView(service).setText(path).setTextSize(13).setPadding(0,0,0,15).setTextColor(0x88FFFFFF)
    mainLayout.addView(pathTxt)
    
    local listView = ListView(service)
    local items = {}
    local fileObjects = {}
    
    if path ~= "/storage/emulated/0" then
      table.insert(items, ".. (Go Back)")
      table.insert(fileObjects, "BACK")
    end
    
    local folder = File(path)
    local filesList = folder.listFiles()
    if filesList ~= nil then
      for i = 0, #filesList - 1 do
        local file = filesList[i]
        if file.isDirectory() and not file.getName():find("^%.") then
          table.insert(items, "Folder: " .. file.getName())
          table.insert(fileObjects, file)
        end
      end
      for i = 0, #filesList - 1 do
        local file = filesList[i]
        if file.isFile() then
          local name = file.getName():lower()
          if name:find("%.mp3$") or name:find("%.wav$") or name:find("%.ogg$") or name:find("%.m4a$") then
            table.insert(items, "Audio: " .. file.getName())
            table.insert(fileObjects, file)
          end
        end
      end
    end
    
    local adapter = ArrayAdapter(service, android.R.layout.simple_list_item_1, items)
    listView.setAdapter(adapter)
    
    listView.setOnItemClickListener(AdapterView.OnItemClickListener({
      onItemClick = function(parent, view, position, id)
        local target = fileObjects[position + 1]
        if target == "BACK" then
          local parentFile = File(path).getParentFile()
          if parentFile ~= nil then showFolderContents(parentFile.getAbsolutePath()) end
        elseif target.isDirectory() then
          showFolderContents(target.getAbsolutePath())
        else
          local selectedFilePath = target.getAbsolutePath()
          _G.prefs.edit()
            .putString("custom_sound_path", selectedFilePath)
            .putBoolean("use_custom_sound", true)
            .putString("selected_fx_filename", "") 
            .commit()
          pickerDialog.dismiss()
          clearUiState()
          bgSpeak("Custom sound updated successfully")
          mainHandler.post(Runnable({run = function() _G.showSettings() end}))
        end
      end
    }))
    
    mainLayout.addView(listView)
    pickerDialog.setView(mainLayout)
    pickerDialog.getWindow().setType(WindowManager.LayoutParams.TYPE_ACCESSIBILITY_OVERLAY)
    pickerDialog.show()
  end
  clearUiState()
  showFolderContents(currentPath)
end

