local function getUniqueBackground()
  local gd = GradientDrawable()
  gd.setColor(0xFF111622) 
  gd.setCornerRadius(40) 
  gd.setStroke(3, 0xFF2196F3) 
  return gd
end

local function applyUniqueButtonTheme(btn, color)
  local gd = GradientDrawable()
  gd.setColor(color or 0xFF2196F3)
  gd.setCornerRadius(20)
  btn.setBackground(gd)
  btn.setTextColor(0xFFFFFFFF)
end

